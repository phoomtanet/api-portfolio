generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model user {
  id         Int            @id @default(autoincrement())
  fullname   String?        @db.VarChar
  username   String?        @db.VarChar
  password   String?        @db.VarChar
  created_at DateTime       @default(now()) @db.Timestamptz(6)
  created_by String?        @db.VarChar
  updated_at DateTime?      @db.Timestamp(6)
  updated_by String?        @db.VarChar
  is_active  Boolean?       @default(true)
  deleted_at DateTime?      @db.Timestamp(6)
  deleted_by String?        @db.VarChar
  email      String?        @db.VarChar
  is_admin   Boolean?       @default(false)
  chat_rooms chat_room[]
  sessions   user_session[]
  restaurant_users restaurant_user[]
}

/// ห้องแชต 1 ห้องต่อ 1 user
model chat_room {
  id         BigInt         @id @default(autoincrement())
  room_key   String         @unique @db.VarChar(100)
  username   String         @db.VarChar(100)
  user_id    Int?
  is_active  Boolean        @default(true)
  created_at DateTime       @default(now()) @db.Timestamptz(6)
  created_by      String?   @db.VarChar
  closed_at  DateTime?      @db.Timestamptz(6)
  messages   chat_message[]
  user       user?          @relation(fields: [user_id], references: [id])

  @@index([is_active])
}

/// ข้อความในห้องแชต
model chat_message {
  id         BigInt    @id @default(autoincrement())
  room_id    BigInt
  file_url   String?    @db.VarChar(2500)
  file_name  String?    @db.VarChar(100)
  sender     String    @db.VarChar(100)
  is_admin   Boolean   @default(false)
  content    String
  is_read    Boolean   @default(false)
  is_active  Boolean        @default(true)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  created_by      String?   @db.VarChar
  deleted_at      DateTime? @db.Timestamp(6)
  deleted_by      String?   @db.VarChar
  updated_at      DateTime? @db.Timestamp(6)
  updated_by      String?   @db.VarChar
  room       chat_room @relation(fields: [room_id], references: [id])

  @@index([room_id, created_at])
}

/// บันทึก session การเข้าใช้งานของผู้ใช้แต่ละครั้ง
model user_session {
  id               BigInt    @id @default(autoincrement())
  user_id          Int  /// SHA-256 ของ JWT token — ใช้ตรวจสอบหรือ revoke session
  token_hash       String    @db.VarChar(64)   /// IP ของผู้ใช้ขณะ login (รองรับ IPv4 และ IPv6)
  ip_address       String?   @db.VarChar(45)   /// User-Agent string — browser / OS / device
  user_agent       String?   /// เวลาที่ login
  login_at         DateTime  @default(now()) @db.Timestamptz(6)   /// เวลาที่เรียก API ล่าสุด
  last_activity_at DateTime? @db.Timestamptz(6)  /// เวลาที่ logout (null = ยังเป็น active session)
  logout_at        DateTime? @db.Timestamptz(6)  /// เวลาที่ token หมดอายุ
  expires_at       DateTime  @db.Timestamptz(6)   /// false เมื่อ logout หรือ token หมดอายุ
  is_active        Boolean   @default(true)
  user             user      @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([token_hash])
  @@index([is_active, expires_at])
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model project {
  id              BigInt    @id @default(autoincrement())
  project_name_th String?   @db.VarChar
  project_name_en String?   @db.VarChar
  is_active       Boolean?  @default(true)
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  created_by      String?   @db.VarChar
  deleted_at      DateTime? @db.Timestamp(6)
  deleted_by      String?   @db.VarChar
  updated_at      DateTime? @db.Timestamp(6)
  updated_by      String?   @db.VarChar
}





model restaurant {
  id              Int    @id @default(autoincrement())
  restaurant_name_th String?   @db.VarChar
  restaurant_name_en String?   @db.VarChar
  is_active       Boolean?  @default(true)
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  created_by      String?   @db.VarChar
  deleted_at      DateTime? @db.Timestamp(6)
  deleted_by      String?   @db.VarChar
  updated_at      DateTime? @db.Timestamp(6)
  updated_by      String?   @db.VarChar
  restaurant_users restaurant_user[]
  restaurant_menus restaurant_menu[]
}

model restaurant_menu {
  id              Int    @id @default(autoincrement())
  restaurant_id   Int?
  menu_name_th    String?   @db.VarChar
  menu_name_en    String?   @db.VarChar
  menu_description_th String?   @db.VarChar
  menu_description_en String?   @db.VarChar
  menu_image      String?   @db.VarChar
  is_active       Boolean?  @default(true)
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  created_by      String?   @db.VarChar
  deleted_at      DateTime? @db.Timestamp(6)
  deleted_by      String?   @db.VarChar
  updated_at      DateTime? @db.Timestamp(6)
  updated_by      String?   @db.VarChar
  Restaurant      restaurant? @relation(fields: [restaurant_id], references: [id])
}


model restaurant_user {
  id              Int    @id @default(autoincrement())
  restaurant_id   Int?
  user_id         Int?
  role_id         Int?
  is_active       Boolean?  @default(true)
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  created_by      String?   @db.VarChar
  deleted_at      DateTime? @db.Timestamp(6)
  deleted_by      String?   @db.VarChar
  updated_at      DateTime? @db.Timestamp(6)
  updated_by      String?   @db.VarChar
  User            user?     @relation(fields: [user_id], references: [id])
  Restaurant      restaurant? @relation(fields: [restaurant_id], references: [id])
  Role            restaurant_role? @relation(fields: [role_id], references: [id])
}


model restaurant_role {
  id              Int    @id @default(autoincrement())
  role_name       String?   @db.VarChar
  is_active       Boolean?  @default(true)
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  created_by      String?   @db.VarChar
  deleted_at      DateTime? @db.Timestamp(6)
  deleted_by      String?   @db.VarChar
  updated_at      DateTime? @db.Timestamp(6)
  updated_by      String?   @db.VarChar
  restaurant_users restaurant_user[]
}